{
    "dataset": {
        "name": "rome",
        "split": "train"
    },
    "env": {
        "step_limit": 1024,
        "type": "move_over_edge",
        "width": 1000,
        "height": 1000,
        "patch_size": 63,
        "pixel_decay_alpha": 0.5,
        "node_selection_strategy": "heuristic_new",
        "node_visit_repeat_count": 5,
        "n_distances": 6,
        "reward_scale": 1.0,
        "reward": {
            "global_optimization": {
                "global_weight": 1.0,
                "sparse_penalty": -0.01
            },
            "local_optimization": {
                "local_weight": 10.0,
                "sizemax_weight": 0.1,
                "global_weight": 1.0,
                "sparse_penalty": -0.01
            }
        },
        "optimization_goal": "global",
        "reset_unsuccessful_moves_threshold": null
    },
    "policy": {
       "features_extractor": {
            "features_dim": 512,
            "pixel_map_key": "pixel_map",
            "cnn_channels": [32, 64, 128],
            "cnn_blocks_per_stage": [2, 2, 2],
            "cnn_pool_out": [4, 4],
            "cnn_out_dim": 256,
            "tab_hidden_dim": 128,
            "tab_out_dim": 128,
            "fusion_hidden_dim": 512,
            "use_se": true,
            "cnn_dropout_p": 0.0
        }
    },
    "ppo": {
        "policy": "MultiInputPolicy",
        "learning_rate": 0.0003,
        "n_steps": 256,
        "batch_size": 128,
        "n_epochs": 2,
        "gamma": 0.99,
        "gae_lambda": 0.95,
        "clip_range": 0.2,
        "ent_coef": 0.01,
        "vf_coef": 0.5,
        "max_grad_norm": 0.5,
        "policy_kwargs": {
            "net_arch": [
                128,
                128
            ]
        }
    },
    "training": {
        "use_action_masks": false,
        "total_timesteps": 4096,
        "n_envs": 2,
        "save_freq": 1024,
        "eval_freq": 1024,
        "log_heatmap": true,
        "heatmap_freq": 1,
        "log_video": true,
        "video_freq": 5
    }
}